class Solution {
public:
    int smallestDivisor(vector<int>& nums, int threshold) {
     int n = nums.size();
     int s= 1;
     int e = *max_element(nums.begin(),nums.end());
     while(s<=e){
      int mid = s + (e - s)/2;
      long long sum = 0;
      for(int i=0;i<n;i++){
        sum+= (nums[i]+mid-1)/mid;
      }  
      if(sum<=threshold){
        e = mid-1;
      }else{
        s = mid+1;
      }
     }   
     return s;
    }
};
