class Solution {
public:
     TreeNode *nextRight = NULL;
    void flatten(TreeNode* root) {
     if(root == NULL){
        return;
     }   
     flatten(root->right);
     flatten(root->left);
     root->left = NULL;
     root->right = nextRight;
     nextRight = root;
    }
};
//t.c. = O(n)
//s.c. = O(h), because of recursive stack
