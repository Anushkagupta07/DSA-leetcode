class Solution {
public:
    int min_diff = INT_MAX;
    TreeNode *prev = NULL;
    void inorder(TreeNode* root){
        if(root == NULL){
            return;
        }
        inorder(root->left);
        if(prev!= NULL){
            min_diff = min(min_diff , root->val -  prev->val);
        }
        prev = root;
        inorder(root->right);
    }
    int minDiffInBST(TreeNode* root) {
    inorder(root);  
    return min_diff; 
    }
};
