class Solution {
  public:
    int helper(Node* root){
        if(root == NULL) return 0;
        int leftSum = helper(root->left);
        int rightSum = helper(root->right);
        int OldVal = root->data;
        root->data = leftSum + rightSum;
        return OldVal + root->data;
    }
    void toSumTree(Node *node) {
    helper(node);
        
    }
};
